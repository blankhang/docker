# Elastic Stack 版本（Swarm stack 镜像 tag）
ELK_VERSION=9.4.1

# Swarm config 版本（修改 conf 后递增，触发挂载新 config）
ELASTIC_CERT_CONFIG_VERSION=v1
# Kibana 已改用 environment，不再挂载 Swarm config（此项保留无影响）
# KIBANA_CONFIG_VERSION=v3

# Elasticsearch elastic 用户密码
ELASTIC_PASSWORD=changeme

# Kibana 连接 ES 的 kibana_system 密码
KIBANA_USERNAME=kibana_system
KIBANA_PASSWORD=changeme

# Kibana 加密密钥（saved objects / security；报表已禁用，无需 REPORTING 密钥）
XPACK_ENCRYPTEDSAVEDOBJECTS_ENCRYPTIONKEY=a2V5IHRoYXQgcmVhbGx5IHdvcmtzIGZvciB0ZXN0
XPACK_SECURITY_ENCRYPTIONKEY=a2V5IHRoYXQgcmVhbGx5IHdvcmtzIGZvciB0ZXN0
