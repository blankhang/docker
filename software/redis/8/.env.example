# 复制为本地配置（勿提交 .env）:
#   cp .env.example .env
#
# 生产环境必须改为强密码，并与下列位置保持一致:
#   - docker-compose: conf/redis.conf 的 requirepass / masterauth
#   - docker-stack:   Swarm Secret redis_1m2r3s_password（见 docker-stack-1m2r3s/README.md）
#   - Spring 示例:    application-redis-*.example.yml 中的 ${REDIS_PASSWORD}

REDIS_PASSWORD=changeme
